# Cartographer Semanticist: LLM and embeddings (optional)
# Copy to .env and set at least one LLM key. Analyze will run the Semanticist and fill
# CODEBASE.md purpose index + onboarding_brief.md day-one answers.

# ---- OpenRouter (bulk tier: Gemini Flash, Mistral, etc.) ----
# Get a key at https://openrouter.ai
# Used for: bulk tier (purpose statements, drift, cluster labels). Also used for synthesis
# if DEEPSEEK_API_KEY is not set.
OPENROUTER_API_KEY=

# OpenRouter model for bulk (cheap/fast). Examples: google/gemini-2.0-flash-001, mistralai/mistral-7b-instruct
CARTOGRAPHER_BULK_MODEL=google/gemini-2.0-flash-001
# OpenRouter model for synthesis when not using DeepSeek direct (e.g. deepseek/deepseek-chat)
CARTOGRAPHER_SYNTHESIS_MODEL=deepseek/deepseek-chat

# ---- DeepSeek API (synthesis tier, optional) ----
# Get a key at https://platform.deepseek.com
# When set: synthesis (Day-One answers) uses DeepSeek's API directly. If OPENROUTER_API_KEY
# is not set, DeepSeek is used for bulk too.
DEEPSEEK_API_KEY=

# DeepSeek model when using DEEPSEEK_API_KEY (e.g. deepseek-chat, deepseek-reasoner)
CARTOGRAPHER_DEEPSEEK_MODEL=deepseek-chat

# ---- Optional: OpenAI for domain clustering embeddings ----
# OPENAI_API_KEY=sk-...
