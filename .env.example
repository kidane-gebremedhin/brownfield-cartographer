# Cartographer Semanticist: LLM and embeddings (optional)
# Copy to .env and set DEEPSEEK_API_KEY. Analyze will run the Semanticist and fill
# CODEBASE.md purpose index + onboarding_brief.md day-one answers.

# ---- DeepSeek API (required for Semanticist) ----
# Get a key at https://platform.deepseek.com
# All LLM calls (purpose statements, drift, cluster labels, Day-One synthesis) use DeepSeek.
DEEPSEEK_API_KEY=

# DeepSeek model for bulk (purpose/drift/cluster). Default: deepseek-chat
CARTOGRAPHER_DEEPSEEK_MODEL=deepseek-chat
# DeepSeek model for synthesis (Day-One answers). Default: deepseek-chat
CARTOGRAPHER_SYNTHESIS_MODEL=deepseek-chat

# ---- Optional: timeouts and limits ----
# LLM HTTP request timeout (seconds). Increase for large repos or slow APIs (default 180).
# CARTOGRAPHER_LLM_TIMEOUT=300

# ---- Optional: OpenAI for domain clustering embeddings ----
# OPENAI_API_KEY=sk-...
